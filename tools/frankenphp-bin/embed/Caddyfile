# Embedded Caddyfile — bakt mee in de static binary.
# Geen externe paden: root verwijst naar `public/` relatief aan de embed-FS.
# Geen worker-mode, geen admin, geen TLS — minimale demo.

{
    admin off
    order scopecache before php_server
    log {
        output stdout
        format console
    }
}

:8080 {
    root * public

    scopecache {
        scope_max_items 1000
        max_store_mb    16
        max_item_mb     1
    }

    # Short-circuit browser auto-fetches so they do NOT fall through
    # to index.php (which would re-fire scopecache_append on every
    # /favicon.ico hit, doubling the apparent append-count per
    # pagina-load). 204 = no content, browser keeps quiet.
    respond /favicon.ico 204
    respond /robots.txt  204

    php_server
}
